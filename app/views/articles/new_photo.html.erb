<div class="form-page" data-controller="camera loading">
  <div class="form-page-body">
    <div class="form-hero">
      <div class="sec-eye">Prendre une photo</div>
      <div class="sec-title">Prends une <em>photo</em></div>
      <p class="sec-sub">Prends en photo n'importe quel texte autour de toi</p>
    </div>

    <%= simple_form_for @article, url: articles_path, html: { enctype: "multipart/form-data" } do |f| %>
      <div class="form-field-group">
        <label class="form-field-label">Titre</label>
        <%= f.text_field :title, class: "form-input", placeholder: "Ex: Affiche, document, menu..." %>
        <p class="form-field-error" data-loading-target="titleError" hidden>
          <i class="fa-solid fa-circle-exclamation"></i> Le titre est obligatoire avant de valider.
        </p>
      </div>

      <label class="photo-drop-zone" for="photo-input">
        <div class="photo-drop-icon">
          <i class="fa-solid fa-camera"></i>
        </div>
        <div class="photo-drop-title">Prends ta photo ici</div>
        <div class="photo-drop-sub">ou appuie pour choisir depuis ta galerie</div>
        <input id="photo-input"
               type="file"
               name="photo"
               accept="image/*"
               capture="environment"
               class="photo-input-hidden"
               data-camera-target="input"
               data-action="change->camera#showPreview">
      </label>

      <div data-camera-target="preview" class="photo-preview-container" hidden>
        <img data-camera-target="img" class="photo-preview-img" alt="Aperçu de la photo">
      </div>

      <%= f.hidden_field :source, value: "photo" %>

      <%= f.button :submit, "Analyser la photo", class: "btn-readapt-full", data: { action: "click->loading#loadingPage" } %>
    <% end %>
  </div>

  <div class="frame">
    <script src="https://unpkg.com/typed.js@3.0.0/dist/typed.umd.js"></script> <%# herb:disable all %>
    <div class="loading-frame">
      <div class="typewriter">
        <div class="slide"><i></i></div>
        <div class="paper"></div>
        <div class="keyboard"></div>
      </div>
      <span id="typed3"></span>
    </div>
    <div class="text"></div>
  </div>
</div>
