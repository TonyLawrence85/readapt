<h1 class="text-center">
  <%= @article.title %>
</h1>

<div class="container">
  <div class="card d-flex">
    <div class="card-body justify-content-between align-items-center">
      <div data-controller="toggle">
        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" id="show-original" checked
                 data-toggle-target="trigger" data-action="change->toggle#toggle">
          <label class="form-check-label" for="show-original">
            Afficher le texte original
          </label>
        </div>

        <% original_text = if @article.content.present?
                              @article.content
                            elsif @article.document.attached?
                              "Fichier importé : #{@article.document.filename}"
                            else
                              "Aucun contenu disponible"
                            end %>
        <blockquote class="blockquote fst-italic text-muted border-start border-3 ps-3" data-toggle-target="content">
          <p><%= original_text %></p>
        </blockquote>
      </div>

      <p><%= @article.translated_content %></p>

      <% if @article.formatted_content.present? %>

        <% colors = TextFormatter.colors_for(current_user.setting.syllable_palette || "blue_red_green") %>

        <style>
          .syl-0 { color: <%= colors[0] %>; }
          .syl-1 { color: <%= colors[1] %>; }
          .syl-2 { color: <%= colors[2] %>; }
        </style>

        <div id="readapt-text" class="mt-3" style="
          font-family: <%= current_user.setting.font || 'OpenDyslexic' %>;
          letter-spacing: <%= current_user.setting.letter_spacing || 'normal' %>;
        ">
          <h5>Texte reformaté pour la dyslexie</h5>
          <%= @article.formatted_content.html_safe %>
        </div>
      <% end %>

    </div>
  </div>
  <%= link_to "Retour", articles_path %>
</div>
