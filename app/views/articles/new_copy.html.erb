<div class="container mt-2" data-controller="loading">
  <h2>Colle ton texte</h2>

  <%= simple_form_for @article, url: articles_path do |f| %>
    <%= f.input :title, :label => "Titre" %>
    <%= f.input :content, :label => "Contenu" %>
    <%= f.hidden_field :source, value: "copy" %>
    <%= f.button :submit, "Créer", class: "btn-readapt", data: { action: "click->loading#loadingPage" } %>
  <% end %>

  <div class="frame">
    <script src="https://unpkg.com/typed.js@3.0.0/dist/typed.umd.js"></script>

    <div class="loading-frame">
      <div class="typewriter">
        <div class="slide"><i></i></div>
        <div class="paper"></div>
        <div class="keyboard"></div>

      </div>
    <span id="typed3"></span>
    </div>
    <div class="text"> <!-- pour la box shadow -->
    </div>
  </div>
</div>
