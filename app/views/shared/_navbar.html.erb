<nav class="topbar-global">
  <% if controller_name == 'articles' && %w[new_copy new_import new_photo].include?(action_name) %>
    <%= link_to root_path, class: "form-back-btn" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
  <% elsif controller_name == 'articles' && action_name == 'show' %>
    <%= link_to articles_path, class: "form-back-btn" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
  <% elsif controller_name == 'settings' %>
    <%= link_to :back, class: "form-back-btn" do %>
      <i class="fa-solid fa-arrow-left"></i>
    <% end %>
  <% else %>
    <div style="width: 34px;"></div>
  <% end %>

  <%= link_to root_path, class: "topbar-logo" do %>
    <%= image_tag "readapt-logo-home.svg", alt: "Readapt" %>
  <% end %>

  <div class="topbar-links">
    <%= link_to "Accueil", root_path %>
    <%= link_to "Mes textes", articles_path %>
    <% if current_user %>
      <%= link_to "Réglages", edit_setting_path(current_user.setting) %>
      <%= link_to "Profil", profile_path %>
    <% end %>
  </div>
  <div class="topbar-spacer"></div>
</nav>
