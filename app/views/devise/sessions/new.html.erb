<div class="auth-page">

  <div class="auth-logo">
    <%= link_to root_path do %>
      <%= image_tag "readapt-logo-home.svg", alt: "Readapt", height: 28 %>
    <% end %>
  </div>

  <div class="auth-tabs">
    <%= link_to new_user_registration_path, class: "auth-tab" do %>Inscription<% end %>
    <div class="auth-tab active">Connexion</div>
  </div>

  <div class="auth-header">
    <div class="auth-icon">
      <i class="fa-solid fa-user"></i>
    </div>
    <div class="auth-title">Connexion</div>
    <p class="auth-sub">Content de te revoir !</p>
  </div>

  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="auth-form">
      <%= f.input :email,
          required: false,
          autofocus: true,
          label: "Email",
          wrapper_html: { class: "auth-field" },
          label_html: { class: "auth-label" },
          input_html: { class: "auth-input", autocomplete: "email", placeholder: "ton@email.fr" } %>

      <%= f.input :password,
          required: false,
          label: "Mot de passe",
          wrapper_html: { class: "auth-field" },
          label_html: { class: "auth-label" },
          input_html: { class: "auth-input", autocomplete: "current-password", placeholder: "••••••••" } %>

      <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi",
          wrapper_html: { class: "auth-remember" } if devise_mapping.rememberable? %>
    </div>

    <button type="submit" class="btn-auth-primary">Se connecter</button>
  <% end %>

  <div class="auth-footer">
    <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
      <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "auth-link-muted" %>
    <% end %>
    <p class="auth-footer-text">
      Pas encore de compte ?
      <%= link_to "Inscris-toi", new_user_registration_path, class: "auth-link" %>
    </p>
  </div>

</div>
