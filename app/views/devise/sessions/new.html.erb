<div class="devise-page">
  <div class="container d-flex flex-column align-items-center py-4">

    <h2 class="mb-4">Log in</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    label: "Email",
                    input_html: { autocomplete: "email" } %>

        <%= f.input :password,
                    required: false,
                    label: "Password",
                    input_html: { autocomplete: "current-password" } %>

        <%= f.input :remember_me, as: :boolean, label: "Remember me" if devise_mapping.rememberable? %>
      </div>

      <div class="d-flex flex-column align-items-center gap-3 w-100">
        <div class="form-actions">
          <%= f.button :submit, "Log in", class: "btn-readapt-primary" %>
        </div>
      </div>
    <% end %>

    <div class="devise-links d-flex flex-column align-items-center gap-3 w-100 mt-3">
      <%= render "devise/shared/links" %>
      <%= link_to "Back", root_path, class: "btn-back-readapt" %>
    </div>

  </div>
</div>
