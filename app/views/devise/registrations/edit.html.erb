<div class="auth-page">

  <div class="auth-logo">
    <%= link_to root_path do %>
      <%= image_tag "readapt-logo-home.svg", alt: "Readapt", height: 28 %>
    <% end %>
  </div>

  <div class="auth-header">
    <div class="auth-icon">
      <i class="fa-solid fa-user-gear"></i>
    </div>
    <div class="auth-title">Mon compte</div>
    <p class="auth-sub">Modifie tes informations</p>
  </div>

  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= f.error_notification message: "Des erreurs ont été détectées :" %>

    <div class="auth-form">
      <%= f.input :email,
          required: true,
          autofocus: true,
          label: "Email",
          wrapper_html: { class: "auth-field" },
          label_html: { class: "auth-label" },
          input_html: { class: "auth-input", autocomplete: "email", placeholder: "ton@email.fr" } %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p class="auth-info-text">
          <i class="fa-solid fa-circle-info"></i>
          En attente de confirmation pour : <%= resource.unconfirmed_email %>
        </p>
      <% end %>

      <%= f.input :password,
          required: false,
          label: "Nouveau mot de passe",
          hint: "Laisse vide si tu ne veux pas le changer",
          wrapper_html: { class: "auth-field" },
          label_html: { class: "auth-label" },
          input_html: { class: "auth-input", autocomplete: "new-password", placeholder: "••••••••" } %>

      <%= f.input :password_confirmation,
          required: false,
          label: "Confirmer le nouveau mot de passe",
          wrapper_html: { class: "auth-field" },
          label_html: { class: "auth-label" },
          input_html: { class: "auth-input", autocomplete: "new-password", placeholder: "••••••••" } %>

      <%= f.input :current_password,
          required: true,
          label: "Mot de passe actuel",
          hint: "Requis pour confirmer tes modifications",
          wrapper_html: { class: "auth-field" },
          label_html: { class: "auth-label" },
          input_html: { class: "auth-input", autocomplete: "current-password", placeholder: "••••••••" } %>
    </div>

    <button type="submit" class="btn-auth-primary">Mettre à jour</button>
  <% end %>

  <div class="auth-footer">
    <%= link_to root_path, class: "auth-link" do %>
      <i class="fa-solid fa-arrow-left"></i> Retour
    <% end %>

    <%= button_to registration_path(resource_name),
          method: :delete,
          data: { turbo_confirm: "Es-tu sûr(e) de vouloir supprimer ton compte ? Cette action est irréversible." },
          class: "btn-delete-account-auth" do %>
      <i class="fa-solid fa-trash-can"></i> Supprimer mon compte
    <% end %>
  </div>

</div>
