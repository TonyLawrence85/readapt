<% palette_options = {
  "blue_red_green"     => { type: :dots,  colors: ["#1E88E5", "#E53935", "#43A047"] },
  "orange_blue_purple" => { type: :dots,  colors: ["#FB8C00", "#1E88E5", "#8E24AA"] },
  "cream_dark_blue"    => { type: :theme, bg: "#194F7A", text: "#FFF8E7" },
  "yellow_black"       => { type: :theme, bg: "#111111", text: "#FFD700" },
  "offwhite_dark_green"=> { type: :theme, bg: "#1B4332", text: "#F5F5DC" },
  "orange_dark_gray"   => { type: :theme, bg: "#2D2D2D", text: "#FF8C00" }
} %>

<%# Ligne 1 : 2 palettes tricolores %>
<div class="palette-tags mt-2">
  <% palette_options.select { |_, d| d[:type] == :dots }.each do |key, data| %>
    <div class="tag-item">
      <input type="radio" name="setting[syllable_palette]" value="<%= key %>"
             id="palette_<%= key %>" class="tag-selector"
             <%= "checked" if @setting.syllable_palette == key %>>
      <label for="palette_<%= key %>" class="palette-label">
        <% data[:colors].each do |color| %>
          <span class="color-dot" style="background-color:<%= color %>;"></span>
        <% end %>
      </label>
    </div>
  <% end %>
</div>

<%# Ligne 2 : 4 palettes thème %>
<div class="palette-tags mt-2">
  <% palette_options.select { |_, d| d[:type] == :theme }.each do |key, data| %>
    <div class="tag-item">
      <input type="radio" name="setting[syllable_palette]" value="<%= key %>"
             id="palette_<%= key %>" class="tag-selector"
             <%= "checked" if @setting.syllable_palette == key %>>
      <label for="palette_<%= key %>" class="palette-label">
        <span class="palette-swatch" style="background:<%= data[:bg] %>;">
          <span style="color:<%= data[:text] %>;">Aa</span>
        </span>
      </label>
    </div>
  <% end %>
</div>
