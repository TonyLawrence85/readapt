
  <div class="mb-3">
    <label>Langue du texte :</label>

    <div class="language-tags">
      <% languages = [
        ["fr", "🇫🇷 Français"],
        ["en", "🇬🇧 English"],
        ["es", "🇪🇸 Español"],
        ["de", "🇩🇪 Deutsch"]
      ] %>

      <% languages.each do |value, label| %>
        <div class="tag-item">
          <input
            type="radio"
            name="language"
            value="<%= value %>"
            id="lang_<%= value %>"
            class="tag-selector"
            <%= "checked" if value == "fr" %>
          >
          <label for="lang_<%= value %>"><%= label %></label>
        </div>
      <% end %>

    </div>
  </div>

  <%= simple_form_for @setting do |f| %>

   <div class="mb-3">
      <label>Police</label>

      <div class="font-tags">

        <% fonts = ["OpenDyslexic", "Arial", "Verdana", "Georgia", "Courier New"] %>

        <% fonts.each do |font| %>
          <div class="tag-item">
            <input
              type="radio"
              name="setting[font]"
              value="<%= font %>"
              id="font_<%= font.parameterize %>"
              class="tag-selector"
              <%= "checked" if @setting.font == font %>
            >

            <label for="font_<%= font.parameterize %>"
                  style="font-family: <%= font %>;">
              <%= font %>
            </label>
          </div>
        <% end %>

      </div>
    </div>

    <div class="mb-3">
      <label>Espacement des lettres</label>

      <input
        type="range"
        min="0"
        max="10"
        step="1"
        value="<%= @setting.letter_spacing.to_s.gsub('px','') || 0 %>"
        id="spacing-input"
        class="form-range"
        name="setting[letter_spacing]"
      >

      <small id="spacing-value">
        <%= @setting.letter_spacing || "0px" %>
      </small>
    </div>

   <div class="mb-3">
    <label>Taille du texte</label>

    <input
      type="range"
      min="12"
      max="40"
      step="1"
      value="<%= @setting.font_size.to_s.gsub('px','') || 16 %>"
      id="size-input"
      class="form-range"
      name="setting[font_size]"
    >

    <small id="size-value">
      <%= @setting.font_size || "16px" %>
    </small>
  </div>

    <h2 id="preview-text"
        style="
          font-family: <%= @setting.font %>;
          letter-spacing: <%= @setting.letter_spacing %>;
          font-size: <%= @setting.font_size %>;
        ">
      Lire avec Readapt, c'est facile !
    </h2>

    <hr>

    <div class="mb-3">
      <label>Palette de couleurs</label>

      <% palettes = {
        "blue_red_green" => ["#1E88E5", "#E53935", "#43A047"],
        "orange_blue_purple" => ["#FB8C00", "#1E88E5", "#8E24AA"],
        "yellow_blue_green" => ["#FDD835", "#1E88E5", "#43A047"]
      } %>

      <div class="palette-tags">

        <% palettes.each do |key, colors| %>
          <div class="tag-item">

            <input
              type="radio"
              name="setting[syllable_palette]"
              value="<%= key %>"
              id="palette_<%= key %>"
              class="tag-selector"
              <%= "checked" if @setting.syllable_palette == key %>
            >

            <label for="palette_<%= key %>" class="palette-label">

              <% colors.each do |color| %>
                <span class="color-dot" style="background-color: <%= color %>;"></span>
              <% end %>

            </label>

          </div>
        <% end %>

      </div>
    </div>

    <%= f.input :syllable_mode,
      as: :boolean,
      label: "Activer la coloration des syllabes",
      input_html: { id: "syllable-mode" }
    %>

    <div id="syllable-preview" class="mb-3"></div>

    <%= f.button :submit, "Enregistrer mes préférences", class: "btn btn-readapt" %>

  <% end %>

</div>
<script>
      document.addEventListener("turbo:load", () => {

  const preview = document.getElementById("preview-text")
  const syllablePreview = document.getElementById("syllable-preview")

  const fontInputs = document.querySelectorAll('input[name="setting[font]"]')
  const paletteInput = document.getElementById("palette-input")
  const spacingInput = document.getElementById("spacing-input")
  const sizeInput = document.getElementById("size-input")
  const syllableMode = document.getElementById("syllable-mode")
  const languageSwitch = document.getElementById("language-switch")

  const palettes = {
    blue_red_green: ["blue", "red", "green"],
    orange_blue_purple: ["orange", "blue", "purple"],
    yellow_blue_green: ["yellow", "blue", "green"]
  }

  const texts = {
    fr: "Lire avec Readapt, c'est facile !",
    en: "Reading with Readapt is easy!",
    es: "Leer con Readapt es fácil!",
    de: "Lesen mit Readapt ist einfach!"
  }

  let currentText = texts["fr"]

  function syllabify(text, colors) {
    return text.split(" ").map(word => {
      return (word.match(/.{1,2}/g) || [word])
        .map((part, i) => {
          let color = colors[i % colors.length]
          return `<span style="color:${color}">${part}</span>`
        }).join("")
    }).join(" ")
  }

  function updatePreview() {
    const colors = palettes[paletteInput.value]

    if (syllableMode.checked) {
      syllablePreview.innerHTML = syllabify(currentText, colors)
    } else {
      syllablePreview.innerHTML = currentText
    }
  }


  const languageInputs = document.querySelectorAll('input[name="language"]')

  languageInputs.forEach(input => {
    input.addEventListener("change", (e) => {
      currentText = texts[e.target.value]
      preview.innerText = currentText
      updatePreview()
    })
  })

  fontInputs.forEach(input => {
    input.addEventListener("change", (e) => {
      preview.style.fontFamily = e.target.value
    })
  })

  paletteInput.addEventListener("change", updatePreview)

 spacingInput.addEventListener("input", (e) => {
    const value = e.target.value + "px"

    preview.style.letterSpacing = value

    // affichage valeur
    const spacingValue = document.getElementById("spacing-value")
    if (spacingValue) {
      spacingValue.innerText = value
    }
  })

  sizeInput.addEventListener("input", (e) => {
    const value = e.target.value + "px"

    preview.style.fontSize = value

    const sizeValue = document.getElementById("size-value")
    if (sizeValue) {
      sizeValue.innerText = value
    }
  })

  syllableMode.addEventListener("change", updatePreview)

  updatePreview()

})

</script>
