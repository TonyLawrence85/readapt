
  <h1 class="text-center mt-3 mb-3">Mes préférences</h1>

  <%= simple_form_for @setting do |f| %>

    <%# ── BOX 1 : Typographie + Aperçu texte ── %>
    <div class="settings-box mb-3" id="typography-box">

      <div class="settings-section">
        <label class="settings-label">
          <i class="fa-solid fa-font"></i> Police
        </label>
        <div class="font-tags">
          <% ["OpenDyslexic", "Arial", "Verdana", "Georgia"].each do |font| %>
            <div class="tag-item">
              <input
                type="radio"
                name="setting[font]"
                value="<%= font %>"
                id="font_<%= font.parameterize %>"
                class="tag-selector"
                <%= "checked" if @setting.font == font %>
              >
              <label for="font_<%= font.parameterize %>" style="font-family: <%= font %>;">
                <%= font %>
              </label>
            </div>
          <% end %>
        </div>
      </div>

      <div class="settings-section">
        <label class="settings-label">
          <i class="fa-solid fa-arrows-left-right"></i> Espacement
        </label>
        <input
          type="range" min="0" max="10" step="1"
          value="<%= @setting.letter_spacing.to_s.gsub('px','') || 0 %>"
          id="spacing-input" class="form-range" name="setting[letter_spacing]"
        >
        <span class="slider-value" id="spacing-value"><%= @setting.letter_spacing || "0px" %></span>
      </div>

      <div class="settings-section">
        <label class="settings-label">
          <i class="fa-solid fa-text-height"></i> Taille
        </label>
        <input
          type="range" min="12" max="40" step="1"
          value="<%= @setting.font_size.to_s.gsub('px','') || 16 %>"
          id="size-input" class="form-range" name="setting[font_size]"
        >
        <span class="slider-value" id="size-value"><%= @setting.font_size || "16px" %></span>
      </div>

      <div class="settings-preview">
        <span
          id="preview-text"
          style="font-family:<%= @setting.font %>; letter-spacing:<%= @setting.letter_spacing %>; font-size:<%= @setting.font_size %>;"
        >Lire avec Readapt, c'est facile !</span>
      </div>

    </div>

    <%# ── BOX 2 : Palette + Mode syllabes + Aperçu syllabes ── %>
    <div class="settings-box mb-3" id="syllable-box">

      <div class="settings-section">
        <label class="settings-label">
          <i class="fa-solid fa-palette"></i> Palette de couleurs
        </label>
        <%= render 'palette' %>
      </div>

      <div class="settings-section syllable-toggle-section">
        <div class="form-check form-switch d-flex align-items-center justify-content-center gap-2">
          <input class="form-check-input" type="checkbox" id="syllable-mode" name="setting[syllable_mode]" value="1" <%= "checked" if @setting.syllable_mode %>>
          <label class="form-check-label settings-label mb-0" for="syllable-mode">
            <i class="fa-solid fa-droplet"></i> Coloration des syllabes
          </label>
        </div>
      </div>

      <div class="settings-section">
        <label class="settings-label">
          <i class="fa-solid fa-eye"></i> Aperçu
        </label>
        <div id="syllable-preview" class="syllable-preview-box"></div>
      </div>

    </div>

    <%= f.button :submit, "Enregistrer mes préférences", class: "btn btn-readapt w-100" %>

  <% end %>


<script>
document.addEventListener("turbo:load", () => {

  const preview         = document.getElementById("preview-text")
  const syllablePreview = document.getElementById("syllable-preview")
  const fontInputs      = document.querySelectorAll('input[name="setting[font]"]')
  const paletteInputs   = document.querySelectorAll('input[name="setting[syllable_palette]"]')
  const spacingInput    = document.getElementById("spacing-input")
  const sizeInput       = document.getElementById("size-input")
  const syllableMode    = document.getElementById("syllable-mode")

  const palettes = {
    blue_red_green:     ["#1E88E5", "#E53935", "#43A047"],
    orange_blue_purple: ["#FB8C00", "#1E88E5", "#8E24AA"],
    yellow_blue_green:  ["#FDD835", "#1E88E5", "#43A047"]
  }

  const previewText = "Lire avec Readapt, c'est facile !"

  function getSelectedPalette() {
    const checked = document.querySelector('input[name="setting[syllable_palette]"]:checked')
    return checked ? checked.value : "blue_red_green"
  }

  function syllabify(text, colors) {
    return text.split(" ").map(word =>
      (word.match(/.{1,2}/g) || [word])
        .map((part, i) => `<span style="color:${colors[i % colors.length]}">${part}</span>`)
        .join("")
    ).join(" ")
  }

  function updatePreview() {
    const colors = palettes[getSelectedPalette()]
    syllablePreview.innerHTML = syllableMode.checked
      ? syllabify(previewText, colors)
      : previewText
  }

  fontInputs.forEach(input => {
    input.addEventListener("change", e => { preview.style.fontFamily = e.target.value })
  })

  paletteInputs.forEach(input => {
    input.addEventListener("change", updatePreview)
  })

  spacingInput.addEventListener("input", e => {
    const val = e.target.value + "px"
    preview.style.letterSpacing = val
    document.getElementById("spacing-value").innerText = val
  })

  sizeInput.addEventListener("input", e => {
    const val = e.target.value + "px"
    preview.style.fontSize = val
    document.getElementById("size-value").innerText = val
  })

  syllableMode.addEventListener("change", updatePreview)

  updatePreview()
})
</script>
