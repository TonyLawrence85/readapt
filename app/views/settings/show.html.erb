<% palettes = {
  "blue_red_green"     => ["#1E88E5", "#E53935", "#43A047"],
  "orange_blue_purple" => ["#FB8C00", "#1E88E5", "#8E24AA"],
  "yellow_blue_green"  => ["#FDD835", "#1E88E5", "#43A047"]
} %>
<% colors = palettes[@setting.syllable_palette] || palettes["blue_red_green"] %>

<h1 class="text-center mt-3 mb-3">Mes préférences</h1>

<div class="mb-3 text-center">
  <label class="settings-label">
    <i class="fa-solid fa-font"></i> Police
  </label>
  <p style="font-family:<%= @setting.font %>;">
    <%= @setting.font %>
  </p>
</div>

<div class="mb-3 text-center">
  <label class="settings-label">
    <i class="fa-solid fa-arrows-left-right"></i> Espacement
  </label>
  <p><%= @setting.letter_spacing || "0px" %></p>
</div>

<div class="mb-3 text-center">
  <label class="settings-label">
    <i class="fa-solid fa-text-height"></i> Taille
  </label>
  <p><%= @setting.font_size || "16px" %></p>
</div>

<div class="mb-3 text-center">
  <label class="settings-label">
    <i class="fa-solid fa-palette"></i> Palette
  </label>
  <div class="d-flex justify-content-center gap-2 mt-1">
    <% colors.each do |c| %>
      <span class="color-dot" style="background:<%= c %>;"></span>
    <% end %>
  </div>
</div>

<div class="mb-3 text-center">
  <label class="settings-label">
    <i class="fa-solid fa-droplet"></i> Coloration des syllabes
  </label>
  <p>
    <% if @setting.syllable_mode %>
      <i class="fa-solid fa-circle-check" style="color:#1B9E7A;"></i> Activée
    <% else %>
      <i class="fa-solid fa-circle-xmark" style="color:#aaa;"></i> Désactivée
    <% end %>
  </p>
</div>

<div class="mb-3 text-center">
  <label class="settings-label">
    <i class="fa-solid fa-eye"></i> Aperçu
  </label>
  <div style="
    font-family:<%= @setting.font %>;
    letter-spacing:<%= @setting.letter_spacing %>;
    font-size:<%= @setting.font_size %>;
    padding:10px;
    border:1px solid #eee;
    border-radius:10px;
  ">
    <%= render_with_settings("Lire avec Readapt, c'est facile !") %>
  </div>
</div>

<%= link_to edit_setting_path(@setting), class: "btn btn-readapt w-100 mt-2" do %>
  <i class="fa-solid fa-pen-to-square me-1"></i> Modifier mes préférences
<% end %>
